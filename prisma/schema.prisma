generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  super_admin
  pg_owner
  pg_staff
}

enum UserStatus {
  active
  inactive
}

enum PGType {
  Boys
  Girls
  CoLiving
}

enum RoomType {
  AC
  NonAC
}

enum PGStatus {
  active
  inactive
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  phone        String
  passwordHash String
  role         Role       @default(pg_owner)
  status       UserStatus @default(active)
  pgId         Int?
  pg           PG?        @relation(fields: [pgId], references: [id], onDelete: SetNull)
  userPGs      UserPG[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Tenant {
  id             Int       @id @default(autoincrement())
  pgId           Int
  pg             PG        @relation(fields: [pgId], references: [id], onDelete: Cascade)
  roomId         Int?
  room           PGRoom?   @relation(fields: [roomId], references: [id], onDelete: SetNull)
  name           String
  phone          String
  aadhar         String
  address        String?
  emergency      String?
  emergencyPhone String?
  idProofUrl     String?
  photoUrl       String?
  moveInDate     DateTime  @default(now())
  moveOutDate    DateTime?
  status         String    @default("active")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  bills          Bill[]
  payments       Payment[]
}

model Room {
  id            Int      @id @default(autoincrement())
  number        String   @unique
  type          String
  totalBeds     Int
  availableBeds Int
  rent          Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Bed {
  id        Int      @id @default(autoincrement())
  number    String   @unique
  room      String
  status    String   @default("vacant")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// PG (Paying Guest) Models
model PG {
  id               Int       @id @default(autoincrement())
  pgName           String
  ownerName        String
  ownerPhone       String
  ownerEmail       String    @unique
  addressLine1     String
  addressLine2     String?
  nearbyMark       String?
  area             String
  city             String
  state            String
  latitude         Float
  longitude        Float
  pgType           PGType
  numberOfRooms    Int
  isFoodAvailable  Boolean   @default(false)
  status           PGStatus  @default(active)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  rooms            PGRoom[]
  photos           PGPhoto[]
  users            User[]
  userPGs          UserPG[]
  expenses         Expense[]
  tenants          Tenant[]
  bills            Bill[]
  payments         Payment[]
}

model PGRoom {
  id              Int      @id @default(autoincrement())
  pgId            Int
  pg              PG       @relation(fields: [pgId], references: [id], onDelete: Cascade)
  roomType        String
  roomNumber      String
  totalBeds       Int
  availableBeds   Int
  pricePerBed     Int
  acType          RoomType
  tenants         Tenant[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([pgId, roomNumber])
}

model PGPhotoCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  photos      PGPhoto[]
}

model UserPG {
  id         Int      @id @default(autoincrement())
  userId     Int
  pgId       Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pg         PG       @relation(fields: [pgId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([userId, pgId])
}

enum ExpenseCategory {
  rent
  electricity
  water
  maintenance
  salary
  food
  internet
  other
}

model Expense {
  id          Int             @id @default(autoincrement())
  pgId        Int
  pg          PG              @relation(fields: [pgId], references: [id], onDelete: Cascade)
  category    ExpenseCategory
  amount      Float
  description String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model PGPhoto {
  id          Int      @id @default(autoincrement())
  pgId        Int
  pg          PG       @relation(fields: [pgId], references: [id], onDelete: Cascade)
  categoryId  Int
  category    PGPhotoCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  photoUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ Billing Models ============

enum BillStatus {
  draft
  pending
  partial
  paid
  overdue
}

enum PaymentMode {
  cash
  upi
  bank_transfer
  cheque
  other
}

enum BillCategory {
  Rent
  Electricity
  Water
  Maintenance
  Salary
  Food
  Internet
  Other
}

model Bill {
  id           Int        @id @default(autoincrement())
  pgId         Int
  pg           PG         @relation(fields: [pgId], references: [id], onDelete: Cascade)
  tenantId     Int
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  billMonth    Int        // 1-12
  billYear     Int
  totalAmount  Float
  paidAmount   Float      @default(0)
  dueAmount    Float
  dueDate      DateTime
  status       BillStatus @default(pending)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  items        BillItem[]
  payments     Payment[]

  @@unique([tenantId, billMonth, billYear])
}

model BillItem {
  id          Int         @id @default(autoincrement())
  billId      Int
  bill        Bill        @relation(fields: [billId], references: [id], onDelete: Cascade)
  label       BillCategory @map("label")
  amount      Float
  createdAt   DateTime    @default(now())
}

model Payment {
  id            Int         @id @default(autoincrement())
  billId        Int
  bill          Bill        @relation(fields: [billId], references: [id], onDelete: Cascade)
  pgId          Int
  pg            PG          @relation(fields: [pgId], references: [id], onDelete: Cascade)
  tenantId      Int
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount        Float
  mode          PaymentMode
  referenceNo   String?
  note          String?
  paidAt        DateTime    @default(now())
  createdAt     DateTime    @default(now())
}

