generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  super_admin
  pg_owner
  pg_staff
}

enum PGType {
  Boys
  Girls
  CoLiving
}

enum RoomType {
  AC
  NonAC
}

enum UserRole {
  Owner
  Manager
}

enum UserStatus {
  active
  inactive
}

enum PGStatus {
  active
  inactive
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(pg_owner)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Guest {
  id             Int      @id @default(autoincrement())
  name           String
  phone          String
  aadhar         String
  address        String?
  emergency      String?
  emergencyPhone String?
  joiningDate    DateTime @default(now())
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Room {
  id            Int      @id @default(autoincrement())
  number        String   @unique
  type          String
  totalBeds     Int
  availableBeds Int
  rent          Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Bed {
  id        Int      @id @default(autoincrement())
  number    String   @unique
  room      String
  status    String   @default("vacant")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// PG (Paying Guest) Models
model PG {
  id               Int       @id @default(autoincrement())
  pgName           String
  ownerName        String
  ownerPhone       String
  ownerEmail       String    @unique
  addressLine1     String
  addressLine2     String?
  nearbyMark       String?
  area             String
  city             String
  state            String
  latitude         Float
  longitude        Float
  pgType           PGType
  numberOfRooms    Int
  isFoodAvailable  Boolean   @default(false)
  status           PGStatus  @default(active)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  rooms            PGRoom[]
  staff            PGStaff[]
  photos           PGPhoto[]
}

model PGRoom {
  id              Int      @id @default(autoincrement())
  pgId            Int
  pg              PG       @relation(fields: [pgId], references: [id], onDelete: Cascade)
  roomType        String
  roomNumber      String
  totalBeds       Int
  availableBeds   Int
  pricePerBed     Int
  acType          RoomType
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([pgId, roomNumber])
}

model PGStaff {
  id        Int        @id @default(autoincrement())
  pgId      Int
  pg        PG         @relation(fields: [pgId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String
  role      UserRole
  username  String     @unique
  password  String
  status    UserStatus @default(active)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PGPhoto {
  id        Int      @id @default(autoincrement())
  pgId      Int
  pg        PG       @relation(fields: [pgId], references: [id], onDelete: Cascade)
  photoUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

